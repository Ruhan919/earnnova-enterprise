{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phpVersion": "8.4",
      "extensions": ["mbstring", "pdo", "pdo_mysql", "pdo_pgsql", "bcmath", "xml", "curl", "gd", "redis", "intl", "zip"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
