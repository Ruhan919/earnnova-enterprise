{
  "name": "earnnova/enterprise",
  "type": "project",
  "description": "EARNNOVA \u2014 Enterprise Earning Platform",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^11.0",
    "laravel/tinker": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {},
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}